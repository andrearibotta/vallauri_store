doctype html
html(lang="it")
    head
        meta(charset="utf-8")
        meta(name="viewport" content="width=device-width, initial-scale=1")
        title= title
        link(rel="stylesheet" href="/styles.css")
    body(class="theme-" + (uiTheme || "dark"))
        .container
            include ./partials/header

            p.muted
                | Questa pagina è renderizzata con
                strong Pug
                | tramite
                code res.render()
                | . I form testano i parser integrati
                strong express.json()
                | ,
                strong express.urlencoded()
                | ,
                strong express.text()
                | , più route MySQL e middleware di sessione/file logger.

            // Esempio esplicito di ciclo Pug (each) su un array passato dal server
            section.card
                h2 Esempio Pug: ciclo each su endpoint di prova
                p.muted Elenco generato nel template tramite variabile passata da server.js
                ul.endpoint-list
                    each item in exampleEndpoints
                        li
                            span.badge= item.method
                            |
                            code= item.path
                            if item.note
                                | - #{item.note}

            // Esempio esplicito di selezione Pug (if/else if/else)
            section.card
                h2 Esempio Pug: Selezione if / else if / else
                if sessionUser
                    p
                        | Stato UI: utente autenticato come
                        strong= sessionUser.username
                        | . Puoi usare subito i pulsanti dall'area privata
                else if demoMode
                    p.muted
                        | Stato UI: modalità demo attiva. Non sei autenticato, ma puoi fare login con demo / demo123.
                else
                    p.muted Stato UI: nessuna sessione e modalità demo disattivata.

            .toolbar
                span.badge Sessione:
                span#sessionPreview.badge (non autenticato)
                span.badge Tema:
                span#themePreview.badge= uiTheme || "dark"
                button#btnThemeLight.theme-toggle(type="button" data-theme="light") Tema chiaro
                button#btnThemeDark.theme-toggle(type="button" data-theme="dark") Tema scuro
                button#btnClearOutput(type="button") Pulisci output
                button#btnLogout(type="button") POST /api/auth/logout

            .grid
                section.card
                    h2 1) Test rapidi
                    .toolbar
                        button#btnPing(type="button") GET /api/ping
                        button#btnDbHealth(type="button") GET /api/db/health
                        button#btnLoadItems(type="button") GET /api/db/items
                        button#btnBoom(type="button") GET /api/boom (errore)
                    p.muted
                        small.code /api/db/* richiede MySQL configurato e script SQL eseguiti.

                section.card
                    h2 2) Login sessione (JSON + cookie)
                    form#loginForm
                        label
                            | Username
                            input(name="username", value="demo", required)
                        label
                            | Password
                            input(name="password", value="demo123" required)
                        button(type="submit") POST /api/auth/login
                    .toolbar(style="margin-top:10px;")
                        button#btnAuthMe(type="button") GET /api/auth/me
                        button#btnWhoAmI(type="button") GET /api/private/whoami
                        button#btnStats(type="button") GET /api/private/db/stats

                section.card
                    h2 3) Inserisci item MySQL (protetto, JSON)
                    form#addItemForm
                        .row3
                            label
                                | Nome
                                input(name="name" value="Mouse USB" required)
                            label
                                | Categoria
                                input(name="category" value="Periferiche" required)
                            label
                                | Quantità
                                input(name="quantity" type="number" min="0" value="4" required)
                        button(type="submit") POST /api/private/db/items

                section.card
                    h2 4) Ricerca MySQL (form-urlencoded)
                    form#searchForm
                        label
                            | Termine di ricerca (name LIKE %term%)
                            input(name="term" value="PC")
                        button(type="submit") POST /api/db/search

                section.card
                    h2 5) Echo JSON (express.json)
                    form#jsonEchoForm
                        label
                            | Titolo
                            input(name="titolo" value="Esercitazione middleware")
                        label
                            | Difficoltà
                            input(name="difficolta" value="intermedia")
                        label
                            input(name="attivo" type="checkbox" checked)
                            | Attivo
                        button(type="submit") POST /api/echo-json

                section.card
                    h2 6) Echo form-urlencoded (express.urlencoded)
                    form#formEchoForm
                        label
                            | Nome
                            input(name="nome" value="Marcello")
                        label
                            | Classe
                            input(name="classe" value="5C")
                        button(type="submit") POST /api/echo-form

                section.card
                    h2 7) Echo testo (express.text)
                    form#textEchoForm
                        label
                            | Testo
                            textarea#plainTextInput Questo body viene letto come stringa tramite express.text()
                        button(type="submit") POST /api/echo-text

                section.card
                    h2 Output risposta
                    pre#output

            include ./partials/footer

        script(src="/app.js")